#include <cstdio>
#include <cstdlib>
#include <cstring>

// Requisito: Estrutura da Sala (Árvore Binária do Mapa)
typedef struct Sala {
    char nome[50];
    char pista[50];
    struct Sala* esquerda;
    struct Sala* direita;
} Sala;

// Requisito: Estrutura do Nó de Pista (Árvore BST)
typedef struct PistaNode {
    char conteudo[50];
    struct PistaNode* esq;
    struct PistaNode* dir;
} PistaNode;

// Requisito: Cria dinamicamente um cômodo
Sala* criarSala(const char* nome, const char* pista) {
    Sala* novaSala = (Sala*)malloc(sizeof(Sala));
    if (novaSala == NULL) exit(1);

    strcpy(novaSala->nome, nome);
    if (pista != NULL) {
        strcpy(novaSala->pista, pista);
    } else {
        strcpy(novaSala->pista, ""); // Sala sem pista
    }
    novaSala->esquerda = NULL;
    novaSala->direita = NULL;
    return novaSala;
}

// Requisito: Insere uma nova pista na árvore BST
PistaNode* inserirPista(PistaNode* raiz, const char* novaPista) {
    if (raiz == NULL) {
        PistaNode* novo = (PistaNode*)malloc(sizeof(PistaNode));
        strcpy(novo->conteudo, novaPista);
        novo->esq = novo->dir = NULL;
        return novo;
    }
    if (strcmp(novaPista, raiz->conteudo) < 0)
        raiz->esq = inserirPista(raiz->esq, novaPista);
    else
        raiz->dir = inserirPista(raiz->dir, novaPista);
    return raiz;
}

// Requisito: Imprime a árvore de pistas em ordem alfabética
void exibirPistas(PistaNode* raiz) {
    if (raiz != NULL) {
        exibirPistas(raiz->esq);
        printf("- %s\n", raiz->conteudo);
        exibirPistas(raiz->dir);
    }
}

// Requisito: Controla a navegação e coleta
PistaNode* explorarMansao(Sala* hall) {
    Sala* atual = hall;
    PistaNode* raizPistas = NULL;
    char escolha;

    while (atual != NULL) {
        printf("\n>>> Voce esta no(a): %s\n", atual->nome);

        // Verifica se há pista e avisa o usuário
        if (strlen(atual->pista) > 0) {
            printf("[!] PISTA ENCONTRADA: %s\n", atual->pista);
            raizPistas = inserirPista(raizPistas, atual->pista);
            // Limpa a pista da sala para não coletar repetido se voltar nela
            strcpy(atual->pista, "");
        } else {
            printf("[i] Nao ha pistas relevantes neste comodo.\n");
        }

        printf("Escolha: [e] Esquerda, [d] Direita ou [s] Sair: ");
        scanf(" %c", &escolha);

        if (escolha == 's' || escolha == 'S') break; // [cite: 28]

        if (escolha == 'e' || escolha == 'E') {
            if (atual->esquerda) atual = atual->esquerda;
            else printf("[X] Caminho bloqueado a esquerda!\n");
        } else if (escolha == 'd' || escolha == 'D') {
            if (atual->direita) atual = atual->direita;
            else printf("[X] Caminho bloqueado a direita!\n");
        }
    }
    return raizPistas;
}

void liberarMapa(Sala* raiz) {
    if (raiz) {
        liberarMapa(raiz->esquerda);
        liberarMapa(raiz->direita);
        free(raiz);
    }
}

int main() {
    // Requisito: Mapa fixo e pré-definido
    Sala* hall = criarSala("Hall de Entrada", NULL);
    Sala* escritorio = criarSala("Escritorio", "Chave Inglesa");
    Sala* salaEstar = criarSala("Sala de Estar", NULL);
    Sala* biblioteca = criarSala("Biblioteca", "Candelabro");
    Sala* salaJogos = criarSala("Sala de Jogos", "Revolver");
    Sala* salaMusica = criarSala("Sala de Musica", "Corda");
    Sala* salaoDanca = criarSala("Salao de Danca", "Faca");
    Sala* cozinha = criarSala("Cozinha", "Cano");
    Sala* salaJantar = criarSala("Sala de Jantar", NULL);

    // Conexões baseadas no seu código original
    hall->esquerda = escritorio;
    hall->direita = salaEstar;
    escritorio->esquerda = biblioteca;
    biblioteca->direita = salaJogos;
    salaJogos->direita = salaMusica;
    salaMusica->esquerda = salaoDanca;
    salaoDanca->direita = cozinha;
    salaEstar->direita = salaJantar;

    PistaNode* inventario = explorarMansao(hall);

    printf("\n========================================\n");
    printf("RELAÇÃO DE PISTAS COLETADAS (A-Z):\n");
    if (inventario == NULL) printf("Nenhuma pista encontrada.\n");
    else exibirPistas(inventario); // [cite: 25]
    printf("========================================\n");

    liberarMapa(hall);
    return 0;
}
