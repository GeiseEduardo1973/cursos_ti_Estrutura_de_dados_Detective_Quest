#include <iostream>
#include <string>
#include <vector>

using namespace std;

// --- ESTRUTURAS DE DADOS ---

// Representa um cômodo na mansão (Árvore Binária) 
struct Sala {
    string nome;
    string pista; // Pista estática associada ao cômodo 
    Sala *esquerda, *direita;
};

// Representa uma pista no inventário (Árvore de Busca Binária - BST) 
struct NoPista {
    string descricao;
    NoPista *esq, *dir;
};

// Item da Tabela Hash para associar Pista -> Suspeito 
struct ItemHash {
    string pista;
    string suspeito;
    bool ocupado = false;
};

// --- FUNÇÕES DO SISTEMA (DOCUMENTADAS)  ---

/**
 * criarSala() – Cria dinamicamente um cômodo da mansão. 
 */
Sala* criarSala(string nome, string pista = "") {
    Sala* nova = new Sala;
    nova->nome = nome;
    nova->pista = pista;
    nova->esquerda = nova->direita = nullptr;
    return nova;
}

/**
 * inserirNaHash() – Insere a associação entre uma pista e um suspeito na tabela. 
 */
void inserirNaHash(ItemHash tabela[], int tam, string pista, string suspeito) {
    int indice = 0;
    for(char c : pista) indice += (unsigned char)c;
    indice %= tam;

    while(tabela[indice].ocupado) {
        indice = (indice + 1) % tam; // Tratamento de colisão linear
    }
    tabela[indice].pista = pista;
    tabela[indice].suspeito = suspeito;
    tabela[indice].ocupado = true;
}

/**
 * encontrarSuspeito() – Consulta qual suspeito corresponde a uma pista na Hash. 
 */
string encontrarSuspeito(ItemHash tabela[], int tam, string pista) {
    int indice = 0;
    for(char c : pista) indice += (unsigned char)c;
    indice %= tam;

    int inicio = indice;
    while(tabela[indice].ocupado) {
        if(tabela[indice].pista == pista) return tabela[indice].suspeito;
        indice = (indice + 1) % tam;
        if(indice == inicio) break;
    }
    return "Desconhecido";
}

/**
 * adicionarPista() – Insere uma pista coletada na árvore BST de forma ordenada. 
 */
NoPista* adicionarPista(NoPista* raiz, string pista) {
    if (pista == "") return raiz;
    if (raiz == nullptr) {
        return new NoPista{pista, nullptr, nullptr};
    }
    if (pista < raiz->descricao) raiz->esq = adicionarPista(raiz->esq, pista);
    else if (pista > raiz->descricao) raiz->dir = adicionarPista(raiz->dir, pista);
    return raiz;
}

/**
 * contarPistasPorAcusado() - Usa recursividade para navegar na BST e validar a acusação. 
 */
void contarPistasPorAcusado(NoPista* raiz, ItemHash tabela[], int tam, string acusado, int &total) {
    if (raiz == nullptr) return;
    contarPistasPorAcusado(raiz->esq, tabela, tam, acusado, total);
    if (encontrarSuspeito(tabela, tam, raiz->descricao) == acusado) {
        total++;
    }
    contarPistasPorAcusado(raiz->dir, tabela, tam, acusado, total);
}

// --- FLUXO PRINCIPAL DO JOGO ---

int main() {
    const int TAM_HASH = 13;
    ItemHash tabelaSuspeitos[TAM_HASH];
    NoPista* inventarioPistas = nullptr;

    // Configuração inicial: Pistas e Suspeitos (Hash) 
    inserirNaHash(tabelaSuspeitos, TAM_HASH, "Candelabro Sujo", "Mordomo");
    inserirNaHash(tabelaSuspeitos, TAM_HASH, "Luva de Seda", "Mordomo");
    inserirNaHash(tabelaSuspeitos, TAM_HASH, "Veneno", "Cozinheira");
    inserirNaHash(tabelaSuspeitos, TAM_HASH, "Faca de Cozinha", "Cozinheira");

    // Montagem do Mapa da Mansão (Árvore Binária) 
    Sala* mansao = criarSala("Hall de Entrada");
    mansao->esquerda = criarSala("Biblioteca", "Candelabro Sujo");
    mansao->direita = criarSala("Cozinha", "Faca de Cozinha");
    mansao->esquerda->esquerda = criarSala("Jardim", "Luva de Seda");
    mansao->direita->direita = criarSala("Despensa", "Veneno");

    Sala* atual = mansao;
    char comando;

    cout << "=== DETECTIVE QUEST: MASTER UPGRADE ===\n";
    cout << "Explore a mansao e colete provas para uma acusacao formal.\n";

    // Loop de Exploração [cite: 14, 34]
    while (true) {
        cout << "\n----------------------------------------";
        cout << "\nVOCE ESTA NO(A): " << atual->nome;
        
        if (atual->pista != "") {
            cout << "\n[!] PISTA DETECTADA: " << atual->pista;
            inventarioPistas = adicionarPista(inventarioPistas, atual->pista);
        }

        cout << "\nComandos: (e)sq | (d)ir | (s)air e acusar: ";
        cin >> comando;

        if (comando == 's') break;

        if (comando == 'e' && atual->esquerda) {
            atual = atual->esquerda;
        } else if (comando == 'd' && atual->direita) {
            atual = atual->direita;
        } else {
            cout << "\n[Aviso] Nao ha caminho por aqui!";
        }
    }

    // Fase de Julgamento 
    string acusado;
    int pistasValidas = 0;

    cout << "\n\n=== TRIBUNAL DE JUSTICA ===";
    cout << "\nDigite o nome do suspeito que voce deseja acusar: ";
    cin >> acusado;

    // Verificação automática via BST + Hash 
    contarPistasPorAcusado(inventarioPistas, tabelaSuspeitos, TAM_HASH, acusado, pistasValidas);

    if (pistasValidas >= 2) {
        cout << "\n[VEREDITO] CULPADO! Voce apresentou " << pistasValidas << " provas incontestaveis contra " << acusado << ".\n";
    } else {
        cout << "\n[VEREDITO] INOCENTE! Provas insuficientes (" << pistasValidas << ") para condenar " << acusado << ".\n";
    }

    return 0;
}
